<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:ignore="ContentDescription">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:padding="@dimen/padding_main">

        <!-- Fluid weight proportion instead of hardcoded 80dp -->
        <ImageView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="16dp"
            android:scaleType="fitCenter"
            android:src="@drawable/ic_check_dgrey_48dp" />

        <!-- M3 Dynamic Typography and Fitts's sizing -->
        <Button
            android:id="@+id/btn_open_dashboard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:minHeight="48dp"
            android:minWidth="48dp"
            android:layout_marginBottom="16dp"
            android:text="Open AirPods Dashboard"
            android:textColor="?colorOnPrimary" />

        <TextView
            android:id="@+id/usage_summary"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:text="Weekly Usage"
            android:textAppearance="?attr/textAppearanceTitleLarge"
            android:textStyle="bold" />

        <!-- Shimmer Placeholder for Perceived Latency -->
        <com.facebook.shimmer.ShimmerFrameLayout
            android:id="@+id/shimmer_view_container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">
                <include layout="@layout/shimmer_history_item" />
                <include layout="@layout/shimmer_history_item" />
            </LinearLayout>
        </com.facebook.shimmer.ShimmerFrameLayout>

        <!-- RecyclerView container natively recycles -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/connection_history"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="2"
            android:layout_marginBottom="24dp" />

        <!-- Dynamically generated ChipGroup for devices -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            android:text="@string/supportedDevicesTitle"
            android:textAppearance="?attr/textAppearanceTitleMedium"
            android:textStyle="bold" />

        <com.google.android.material.chip.ChipGroup
            android:id="@+id/supported_devices_chipgroup"
            android:layout_width="match_parent"
            android:layout_height="wrap_content" />

    </LinearLayout>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
